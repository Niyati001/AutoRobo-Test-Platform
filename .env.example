# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=arvp
POSTGRES_PASSWORD=arvp_pass
POSTGRES_DB=arvp_db

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── SQLAlchemy async URL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://arvp:arvp_pass@postgres:5432/arvp_db

# ─── Authentication ──────────────────────────────────────────────────────────
# IMPORTANT: Replace with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── Simulation ──────────────────────────────────────────────────────────────
# Options: synthetic | isaac
SIMULATION_MODE=synthetic

# ─── Telemetry ───────────────────────────────────────────────────────────────
TELEMETRY_PUBLISH_RATE_HZ=10

# ─── Grafana ─────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=admin123

# ─── Service Internal URLs (used by api-gateway) ─────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8006
TELEMETRY_SERVICE_URL=http://telemetry-service:8001
SIMULATION_SERVICE_URL=http://simulation-service:8002
VALIDATION_SERVICE_URL=http://validation-service:8003
FAULT_INJECTION_SERVICE_URL=http://fault-injection-service:8004
DIAGNOSTICS_SERVICE_URL=http://diagnostics-service:8005
ANALYTICS_SERVICE_URL=http://analytics-service:8007
NOTIFICATION_SERVICE_URL=http://notification-service:8008

# ─── Notification Webhooks (optional) ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/ME/CHANGE_ME
PAGERDUTY_ROUTING_KEY=change-me-pagerduty-routing-key

# ─── Environment ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
